{% extends 'partials/base.html.twig' %}

{% block hero_title %}
    {% include 'partials/content-title.html.twig' %}

    {# Meta info for news items #}
    {% if page.header.date or page.header.author %}
    {# WCAG 1.4.3 - text-gray-700 ensures 4.5:1 contrast ratio #}
    <div class="flex flex-wrap justify-center items-center gap-8 -mt-12 mb-4 text-base text-gray-700">
        {% if page.date %}
        <span class="inline-flex items-center">
            {{ fa_icon('regular/calendar.svg', 'w-4 h-4 mr-1.5 opacity-75')|raw }}
            {{ page.date|date('F j, Y') }}
        </span>
        {% endif %}
        {% if page.header.author %}
        <span class="inline-flex items-center">
            {{ fa_icon('regular/user.svg', 'w-4 h-4 mr-1.5 opacity-75')|raw }}
            {{ page.header.author }}
        </span>
        {% endif %}
    </div>
    {% endif %}
    {# Tags - WCAG 1.4.3 bg-gray-800 ensures 4.5:1 contrast with white text #}
    <div class="flex flex-wrap justify-center gap-1 pb-8 max-w-lg mx-auto">
        {% for tag in page.taxonomy.tag %}
            <a href="{{ page.parent.url ~ '/?tags=' ~ tag }}">
                <span class="inline-flex nowrap text-sm px-2 py-0.5 rounded-md bg-gray-800 text-white">{{ tag }}</span>
            </a>
        {% endfor %}
    </div>
{% endblock %}

{% block content %}
    {% set is_news_item = page.parent.template == 'news' %}

    {% if is_news_item %}
    {# News item with sidebar #}
    <div class="grid lg:grid-cols-3 lg:-mx-8 lg:divide-x lg:divide-gray-200 dark:lg:divide-gray-700 mb-16">
        {# Sidebar #}
        <div class="order-2 lg:order-1 pb-8 prose px-4 lg:px-8">
            {% include 'partials/blog/news-sidebar.html.twig' with { parent_page: page.parent, interactive: false } %}
        </div>

        {# Main content #}
        <div class="order-1 lg:order-2 lg:col-span-2 lg:px-8">
            <article id="article-content" class="prose max-w-none pb-8 px-4 lg:px-0">
                {{ page.content|raw }}
            </article>

            {% include 'partials/article-pagination.html.twig' %}
        </div>
    </div>
    {% else %}
    {# Regular item without sidebar #}
    <article id="article-content" class="prose mx-auto max-w-screen-md pb-16 px-4">
        {{ page.content|raw }}

        {% if config.site.guidelines.boilerplate %}
            <hr />
            <aside class="mt-12">
                {{ config.site.guidelines.boilerplate|markdown }}
            </aside>
        {% endif %}
    </article>



    {% include 'partials/article-pagination.html.twig' %}
    {% endif %}
{% endblock %}