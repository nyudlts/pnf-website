{% set is_htmx = is_htmx|default(false) %}
{% set start = start|default(0) %}
{% set posts = posts|default([]) %}
{% set search_placeholder = search_placeholder|default('Search...') %}

<div x-data="guidelinesFilter" class="grid mb-16 lg:-mx-8 lg:divide-x lg:divide-gray-200 dark:lg:divide-gray-700 lg:grid-cols-3">
    <div class="pb-8 prose px-4 lg:px-8">
        <div class="lg:sticky lg:top-[100px] [&>h2]:mt-0">
            <h2 id="filters-heading" class="text-lg">Filters:</h2>
            <div class="not-prose" role="search" aria-labelledby="filters-heading">
                <div class="mb-4">
                    {# WCAG 1.3.1, 3.3.2 - Accessible label for search input #}
                    <label for="post-search" class="sr-only">{{ search_placeholder }}</label>
                    <input type="text"
                           id="post-search"
                           x-model="searchQuery"
                           @input="onSearchInput()"
                           placeholder="{{ search_placeholder }}"
                           class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                </div>
                {% include 'partials/taxonomylist.html.twig' with {'base_url':page.url, 'taxonomy':'tag', 'children_only': true, 'of_page': page} %}
            </div>
        </div>
    </div>
    <div id="blog-col-2" class="space-y-8 lg:px-8">
        {% for post in posts %}
            {% set global_index = start + loop.index0 %}
            {% if global_index is even %}
                {% include 'partials/blog/post-card.html.twig' with { post: post } %}
            {% endif %}
        {% endfor %}
    </div>
    <div id="blog-col-3" class="space-y-8 lg:px-8">
        {% for post in posts %}
            {% set global_index = start + loop.index0 %}
            {% if global_index is odd %}
                {% include 'partials/blog/post-card.html.twig' with { post: post } %}
            {% endif %}
        {% endfor %}
    </div>
</div>
