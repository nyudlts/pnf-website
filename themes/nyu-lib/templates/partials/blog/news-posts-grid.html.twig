{# News posts grid - includes filters sidebar with recent posts #}
{% set is_htmx = is_htmx|default(false) %}
{% set start = start|default(0) %}
{% set posts = posts|default([]) %}
{% set all_posts = all_posts|default([]) %}
{% set search_placeholder = search_placeholder|default('Search updates...') %}

<div x-data="guidelinesFilter" class="grid mb-16 lg:-mx-8 lg:divide-x lg:divide-gray-200 dark:lg:divide-gray-700 lg:grid-cols-3">
    {# Sidebar with filters and recent posts #}
    <div class="pb-8 prose px-4 lg:px-8">
        {% include 'partials/blog/news-sidebar.html.twig' with { parent_page: page, interactive: true } %}
    </div>

    {# Posts columns #}
    <div id="blog-col-2" class="space-y-8 lg:px-8">
        {% for post in posts %}
            {% set global_index = start + loop.index0 %}
            {% if global_index is even %}
                {% include 'partials/blog/news-post-card.html.twig' with { post: post } %}
            {% endif %}
        {% endfor %}
    </div>
    <div id="blog-col-3" class="space-y-8 lg:px-8">
        {% for post in posts %}
            {% set global_index = start + loop.index0 %}
            {% if global_index is odd %}
                {% include 'partials/blog/news-post-card.html.twig' with { post: post } %}
            {% endif %}
        {% endfor %}
    </div>
</div>
