<article data-guideline-card data-tags="{{ post.taxonomy.tag|json_encode }}" data-title="{{ post.title }}">
    <h2 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
        <a href="{{ post.url }}" class="hover:text-primary-700 focus:outline-none focus:underline">{{ post.title }}</a>
    </h2>
    <div class="flex flex-wrap gap-1 mb-4">
        {% for tag in post.taxonomy.tag %}
            <span class="inline-flex nowrap text-xs px-2 py-0.5 rounded-md bg-gray-200 text-gray-700">{{ tag }}</span>
        {% endfor %}
    </div>
    {# WCAG 1.4.3 - text-gray-600 meets 4.5:1 contrast ratio #}
    <div class="mb-4 font-light text-gray-600 dark:text-gray-300">
        {{ (post.header.summary ?? post.summary)|raw }}
    </div>

    {# WCAG 1.4.3 - text-gray-900 ensures 4.5:1 contrast ratio #}
    <a href="{{ post.url }}"
       class="inline-flex items-center font-medium text-gray-900 hover:text-primary-700 hover:underline focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 rounded dark:text-gray-100">
        Read more {{ fa_icon('regular/arrow-right-long.svg', 'text-current w-5 h-5 ml-2')|raw }}
    </a>
</article>
