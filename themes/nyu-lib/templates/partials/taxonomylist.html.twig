{% set taxlist = children_only is defined ? taxonomylist.getChildPagesTags(of_page, children_only) : taxonomylist.get() %}
{% set link_mode = link_mode|default(false) %}

{% if taxlist %}
<div class="flex flex-wrap gap-1 mr-4" role="group" aria-label="Filter by tags">
    {% for tax,value in taxlist[taxonomy] %}
        {% if link_mode %}
        {# Link mode: navigate to parent page with tag filter #}
        <a href="{{ base_url }}?tags={{ tax|url_encode }}"
           class="inline-flex text-sm px-4 py-1 rounded-md transition-colors cursor-pointer bg-gray-200 text-gray-700 hover:bg-primary-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
            {{ tax }}
        </a>
        {% else %}
        {# Interactive mode: use Alpine.js for filtering - WCAG 4.1.2 with aria-pressed #}
        <button type="button"
                @click="toggleTag('{{ tax }}')"
                :aria-pressed="isSelected('{{ tax }}').toString()"
                :class="isSelected('{{ tax }}') ? 'bg-primary-700 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'"
                class="inline-flex text-sm px-4 py-1 rounded-md transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
            {{ tax }}
        </button>
        {% endif %}
    {% endfor %}
</div>
{% if not link_mode %}
{# WCAG 1.4.3 - text-gray-900 ensures 4.5:1 contrast ratio #}
<button type="button"
        x-show="hasFilters()"
        x-transition
        @click="clearFilters()"
        class="mt-3 inline-flex items-center text-sm text-gray-900 hover:text-primary-700 hover:underline cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 rounded">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
    Clear filters
</button>
{% endif %}
{% endif %}
