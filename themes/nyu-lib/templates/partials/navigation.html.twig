{% macro nav_loop(page) %}
    {% import _self as macros %}
    {% for p in page.children.visible %}
        {% set is_active_page = (p.active or p.activeChild) %}
        {% set active_classes = is_active_page ? 'text-gray-900' : 'text-primary-800' %}
        {% set has_children = p.children.visible.count > 0 %}
        {% set is_clickable = p.header.clickable is not same as(false) %}

        {% if has_children %}
            {# Parent item with dropdown #}
            <li x-data="{ open: false, isMobile: window.innerWidth < 1024 }"
                x-init="window.addEventListener('resize', () => isMobile = window.innerWidth < 1024)"
                class="relative group"
                @mouseenter="if (!isMobile) open = true"
                @mouseleave="if (!isMobile) open = false">

                {# Desktop: hover trigger with optional link / Mobile: just a label #}
                {% if is_clickable %}
                    {# Clickable parent - link on desktop, label on mobile #}
                    <a href="{{ p.url }}"
                       class="flex items-center gap-1 py-2 pr-4 pl-3 {{ active_classes }} hover:text-primary-700 lg:py-0 lg:pr-0 lg:pl-0"
                       :class="{ 'pointer-events-none': isMobile }"
                       {% if is_active_page %} aria-current="page" {% endif %}>
                        {{ p.menu }}
                        <svg class="w-3 h-3 fill-current transition-transform lg:group-hover:rotate-180 max-lg:hidden"
                             :class="{ 'rotate-180': open }"
                             viewBox="0 0 20 20" aria-hidden="true">
                            <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/>
                        </svg>
                    </a>
                {% else %}
                    {# Non-clickable parent - button on desktop for hover, label on mobile #}
                    <span class="flex items-center gap-1 py-2 pr-4 pl-3 {{ active_classes }} lg:py-0 lg:pr-0 lg:pl-0 lg:cursor-pointer">
                        {{ p.menu }}
                        <svg class="w-3 h-3 fill-current transition-transform lg:group-hover:rotate-180 max-lg:hidden"
                             :class="{ 'rotate-180': open }"
                             viewBox="0 0 20 20" aria-hidden="true">
                            <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/>
                        </svg>
                    </span>
                {% endif %}

                {# Dropdown menu - always visible on mobile, hover-triggered on desktop #}
                <ul x-show="open || isMobile"
                    x-cloak
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 lg:translate-y-1"
                    x-transition:enter-end="opacity-100 lg:translate-y-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100 lg:translate-y-0"
                    x-transition:leave-end="opacity-0 lg:translate-y-1"
                    class="lg:absolute lg:left-0 lg:top-full lg:mt-2 lg:min-w-[220px] lg:bg-white lg:rounded-lg lg:shadow-xl lg:border lg:border-gray-200 lg:py-2 lg:z-[100]
                           max-lg:pl-4 max-lg:mt-1 max-lg:border-l-2 max-lg:border-primary-200 max-lg:ml-3"
                    role="menu">
                    {% for child in p.children.visible %}
                        {% set child_active = child.active %}
                        {% set child_active_classes = child_active ? 'text-gray-900 lg:bg-gray-50' : 'text-primary-800' %}
                        <li role="none">
                            <a href="{{ child.url }}"
                               class="block py-2 px-4 {{ child_active_classes }} hover:text-primary-700 lg:hover:bg-gray-50"
                               role="menuitem"
                               {% if child_active %} aria-current="page" {% endif %}>
                                {{ child.menu }}
                            </a>
                            {% if child.children.visible.count > 0 %}
                            <ul role="group">
                                {% for grandchild in child.children.visible %}
                                    {% set gc_active = (grandchild.active or grandchild.activeChild) %}
                                    {% set gc_active_classes = gc_active ? 'text-gray-900 lg:bg-gray-50' : 'text-gray-500' %}
                                    <li role="none">
                                        <a href="{{ grandchild.url }}"
                                           class="block py-1.5 pl-8 pr-4 text-sm {{ gc_active_classes }} hover:text-primary-700 lg:hover:bg-gray-50"
                                           role="menuitem"
                                           {% if gc_active %} aria-current="page" {% endif %}>
                                            {{ grandchild.menu }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </li>
        {% else %}
            {# Regular nav item without children #}
            <li>
                <a href="{{ p.url }}"
                   class="block py-2 pr-4 pl-3 {{ active_classes }} hover:text-primary-700 lg:py-0 lg:pr-0 lg:pl-0"
                   {% if is_active_page %} aria-current="page" {% endif %}>
                    {{ p.menu }}
                </a>
            </li>
        {% endif %}
    {% endfor %}
{% endmacro %}

{{ _self.nav_loop(pages) }}
