{% set pagination = pagination|default(page.collection.params.pagination) %}
{% set base_url = base_url|default(page.url) %}
{% set li_class = 'flex items-center border-r last:border-0 border-gray-300 dark:border-gray-700' %}
{% set item_class = 'inline-block px-4 py-2' %}
{% set disabled_class = 'text-gray-400 dark:text-gray-600' %}
{% set link_class = 'text-primary-700 hover:text-primary-800 hover:bg-gray-50 dark:text-primary-400 dark:hover:text-primary-300 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary-500' %}
{% set icon_left = svg_icon('tabler/chevrons-left.svg', 'w-5') %}
{% set icon_right = svg_icon('tabler/chevrons-right.svg', 'w-5') %}

{% if pagination|length > 1 %}
  <nav aria-label="Pagination">
  <ul class="flex border rounded-md border-gray-300 dark:border-gray-700">
    {% if pagination.hasPrev %}
      {% set url =  (base_url ~ pagination.params ~ pagination.prevUrl)|replace({'//':'/'}) %}
      <li class="{{ li_class }}">
        <a class="{{ item_class }} {{ link_class }}" rel="prev" href="{{ url }}" aria-label="Go to previous page">
          <span aria-hidden="true">{{ icon_left|raw }}</span>
          <span class="sr-only">Previous page</span>
        </a>
      </li>
    {% else %}
      <li class="{{ li_class }}">
        <span class="{{ item_class }} {{ disabled_class }}" aria-disabled="true" aria-label="No previous page">
            <span aria-hidden="true">{{ icon_left|raw }}</span>
        </span>
      </li>
    {% endif %}

    {% for paginate in pagination %}

      {% if paginate.isCurrent %}
        <li class="{{ li_class }}">
          <span class="{{ item_class }} font-bold text-gray-900 dark:text-white" aria-current="page" aria-label="Page {{ paginate.number }}, current page">
            {{ paginate.number }}
          </span>
        </li>
      {% elseif paginate.isInDelta %}
        {% set url = (base_url ~ pagination.params ~ paginate.url)|replace({'//':'/'}) %}
        <li class="{{ li_class }}">
          <a class="{{ item_class }} {{ link_class }}" href="{{ url }}" aria-label="Go to page {{ paginate.number }}">
            {{ paginate.number }}
          </a>
        </li>
      {% elseif paginate.isDeltaBorder %}
        <li class="{{ li_class }}"><span class="{{ item_class }} {{ disabled_class }}" aria-hidden="true">&hellip;</span></li>
      {% endif %}

    {% endfor %}
    {% if pagination.hasNext %}
      {% set url = (base_url ~ pagination.params ~ pagination.nextUrl)|replace({'//':'/'}) %}
      <li class="{{ li_class }}">
        <a class="{{ item_class }} {{ link_class }}" rel="next" href="{{ url }}" aria-label="Go to next page">
          <span aria-hidden="true">{{ icon_right|raw }}</span>
          <span class="sr-only">Next page</span>
        </a>
      </li>
    {% else %}
      <li class="{{ li_class }}">
        <span class="{{ item_class }} {{ disabled_class }}" aria-disabled="true" aria-label="No next page">
          <span aria-hidden="true">{{ icon_right|raw }}</span>
        </span>
      </li>
    {% endif %}
  </ul>
  </nav>

{% endif %}
