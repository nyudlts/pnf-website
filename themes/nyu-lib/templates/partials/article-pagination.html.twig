{# Article pagination with prev/next titles #}
{# Grav siblings are based on filesystem order (alphabetical by folder name).
   With date-prefixed folders (YYYY-MM-DD-slug), alphabetical = chronological ASC:
   - prevSibling = older article (earlier in alphabet/time)
   - nextSibling = newer article (later in alphabet/time)

   For navigation, "Previous" means older, "Next" means newer #}
{% set older_page = page.prevSibling %}
{% set newer_page = page.nextSibling %}

{# Filter out invalid siblings (self-references or missing titles) #}
{% if older_page and (older_page.rawRoute == page.rawRoute or not older_page.title) %}
    {% set older_page = null %}
{% endif %}
{% if newer_page and (newer_page.rawRoute == page.rawRoute or not newer_page.title) %}
    {% set newer_page = null %}
{% endif %}

{% if older_page or newer_page %}
<nav class="border-t border-gray-200 dark:border-gray-700 mt-12 pt-8 mb-4 lg:-mb-4">
    <div class="flex flex-col sm:flex-row justify-between gap-4 max-w-screen-lg mx-auto px-4">
        {# Previous (older) article #}
        {% if older_page %}
        <a href="{{ older_page.url }}"
           class="group flex items-start gap-3 p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors flex-1">
            <span class="mt-1">{{ fa_icon('regular/chevron-left.svg', 'w-4 h-4 text-gray-400 flex-shrink-0')|raw }}</span>
            <div class="min-w-0">
                <span class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Previous</span>
                <span class="block text-sm font-medium text-gray-900 dark:text-white group-hover:text-primary-600 line-clamp-2">
                    {{ older_page.title }}
                </span>
            </div>
        </a>
        {% else %}
        <div class="flex-1"></div>
        {% endif %}

        {# Next (newer) article #}
        {% if newer_page %}
        <a href="{{ newer_page.url }}"
           class="group flex items-start gap-3 p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors flex-1 sm:text-right">
            <div class="min-w-0 flex-1 sm:order-1">
                <span class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Next</span>
                <span class="block text-sm font-medium text-gray-900 dark:text-white group-hover:text-primary-600 line-clamp-2">
                    {{ newer_page.title }}
                </span>
            </div>
            <span class="mt-1 sm:order-2">{{ fa_icon('regular/chevron-right.svg', 'w-4 h-4 text-gray-400 flex-shrink-0')|raw }}</span>
        </a>
        {% else %}
        <div class="flex-1"></div>
        {% endif %}
    </div>
</nav>
{% endif %}
