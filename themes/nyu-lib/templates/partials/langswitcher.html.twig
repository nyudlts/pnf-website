{% set display_format = display_format ?? config.get('plugins.langswitcher.language_display', 'long') %}
{% set language_flags = {
    'en-gb': '🇬🇧',
    'en-us': '🇺🇸',
    'pt-br': '🇧🇷',
    'de-de': '🇩🇪',
    'es-es': '🇪🇸',
    'fr-fr': '🇫🇷',
    'it-it': '🇮🇹',
    'nl-nl': '🇳🇱',
    'pl-pl': '🇵🇱',
    'pt-pt': '🇵🇹'
} %}

{% set lang_switcher_current = {
    code: '',
    label: '',
    url: '',
    flag: '🌐'
} %}
{% set lang_switcher_options = [] %}

{% for language in langswitcher.languages %}
    {% set active_class = '' %}
    {% set show_language = true %}

    {% if language == langswitcher.current %}
        {% set active_class = 'active' %}
    {% endif %}

    {% if langswitcher.translated_routes[language] %}
        {% set lang_url = langswitcher.translated_routes[language] ~ page.urlExtension %}
    {% else %}
        {% set base_lang_url = base_url_simple ~ grav.language.getLanguageURLPrefix(language) %}
        {% set lang_url = base_lang_url ~ langswitcher.page_route ~ page.urlExtension %}
    {% endif %}

    {% set untranslated_pages_behavior = grav.config.plugins.langswitcher.untranslated_pages_behavior %}
    {% if untranslated_pages_behavior != 'none' %}
        {% set translated_page = langswitcher.translated_pages[language] %}
        {% if (not translated_page) or (not translated_page.published) %}
            {% if untranslated_pages_behavior == 'redirect' %}
                {% set lang_url = url('/') %}
            {% elseif untranslated_pages_behavior == 'hide' %}
                {% set show_language = false %}
            {% endif %}
        {% endif %}
    {% endif %}

    {% if show_language %}
        {% set label %}
            {% include 'partials/langswitcher-' ~ display_format ~ '.html.twig' %}
        {% endset %}
        {% set option = {
            code: language,
            label: label|striptags|trim,
            url: lang_url ~ uri.params ~ (uri.query|length > 1 ? '?' ~ uri.query),
            flag: language_flags[language]|default('🌐'),
            active: active_class == 'active'
        } %}

        {% if option.active %}
            {% set lang_switcher_current = option %}
        {% else %}
            {% set lang_switcher_options = lang_switcher_options|merge([option]) %}
        {% endif %}
    {% endif %}
{% endfor %}

{% if lang_switcher_current.code is empty %}
    {% set fallback_language = langswitcher.current %}
    {% set lang_switcher_current = {
        code: fallback_language,
        label: native_name(fallback_language)|default(fallback_language)|capitalize,
        url: page.url,
        flag: language_flags[fallback_language]|default('🌐')
    } %}
{% endif %}

{% set component_payload = {
    current: lang_switcher_current,
    options: lang_switcher_options
} %}
{% set component_payload_json = component_payload|json_encode(constant('JSON_UNESCAPED_SLASHES')) %}

<div class="relative w-full max-w-[200px]" x-data='languageSwitcher({{ component_payload_json|replace({"'": '&#039;'}) }})' x-cloak>
    <button
        type="button"
        class="flex w-full items-center justify-between gap-2 rounded-md border border-primary-500/50 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm transition hover:border-primary-500 hover:text-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-primary-400 dark:hover:text-primary-300"
        @click="toggle()"
        @keydown="onTriggerKeydown($event)"
        :aria-expanded="open.toString()"
        aria-haspopup="listbox"
        x-ref="trigger"
    >
        <span class="flex items-center gap-2">
            <span class="text-lg leading-none" x-text="current.flag">{{ lang_switcher_current.flag }}</span>
            <span x-text="current.label">{{ lang_switcher_current.label }}</span>
        </span>
        <svg class="h-4 w-4 text-slate-500 transition-transform" :class="{'rotate-180': open}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.25a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
        </svg>
    </button>

    <div
        x-show="open"
        x-transition.origin.top
        class="absolute z-50 mt-2 w-full min-w-[200px] rounded-md border border-slate-200 bg-white py-1 shadow-lg focus:outline-none dark:border-slate-600 dark:bg-slate-800"
        @click.outside="close()"
        @keydown.escape.window="close()"
        role="listbox"
        aria-label="Language selection"
        x-ref="optionsList"
    >
        {% if lang_switcher_options is not empty %}
            <template x-for="option in options" :key="option.code">
                <a
                    class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-primary-600 focus:bg-slate-100 focus:text-primary-600 focus:outline-none dark:text-slate-200 dark:hover:bg-slate-700 dark:hover:text-primary-300 dark:focus:bg-slate-700 dark:focus:text-primary-300"
                    :href="option.url"
                    role="option"
                    @keydown="onOptionKeydown($event)"
                    data-option
                >
                    <span class="text-lg leading-none" x-text="option.flag">🌐</span>
                    <span x-text="option.label">Language</span>
                </a>
            </template>
        {% else %}
            <span class="block px-3 py-2 text-sm text-slate-500">No other languages available</span>
        {% endif %}
    </div>
</div>
