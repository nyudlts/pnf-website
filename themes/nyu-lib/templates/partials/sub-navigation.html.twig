{# Sub-navigation for project pages - shows sibling/child page links #}
{% set project_root = null %}

{# Current page is a project root (direct child of projects listing) #}
{% if page.parent and page.parent.slug == 'projects' %}
    {% set project_root = page %}
{# Current page is a child of a project root #}
{% elseif page.parent and page.parent.parent and page.parent.parent.slug == 'projects' %}
    {% set project_root = page.parent %}
{# Current page is a grandchild of a project root (e.g., a news item under updates) #}
{% elseif page.parent and page.parent.parent and page.parent.parent.parent and page.parent.parent.parent.slug == 'projects' %}
    {% set project_root = page.parent.parent %}
{% endif %}

{% if project_root and project_root.children.visible.count > 0 %}
<nav aria-label="Project sections" class="border-b border-gray-200 bg-white">
    <div class="mx-auto max-w-screen-xl px-4">
        <ul class="flex flex-wrap gap-x-8 justify-center -mb-px" role="list">
            {% for child in project_root.children.visible %}
                {% set is_active = (child.active or child.activeChild) %}
                <li>
                    <a href="{{ child.url }}"
                       class="inline-block py-3 text-sm font-medium border-b-2 transition-colors {{ is_active ? 'border-primary-700 text-gray-900' : 'border-transparent text-gray-600 hover:text-gray-900 hover:border-gray-300' }}"
                       {% if is_active %}aria-current="{% if child.active %}page{% else %}true{% endif %}"{% endif %}>
                        {{ child.menu }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    </div>
</nav>
{% endif %}
