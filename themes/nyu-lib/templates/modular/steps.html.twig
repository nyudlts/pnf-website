<section class="bg-linear-to-b from-white to-gray-100 dark:from-gray-900 dark:to-gray-800">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
        <div class="mx-auto max-w-screen-sm mb-8 lg:mb-16 text-center">
            <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white">{{ page.title }}</h2>
            {% if page.header.subtitle %}
            <p class="font-light text-gray-500 sm:text-xl dark:text-gray-400">{{ page.header.subtitle }}</p>
        </div>
        {% endif %}
        <div class="space-y-8 md:grid md:grid-cols-3 md:gap-8 md:space-y-0">
            {% for step in page.header.steps %}
            <div class="p-6 bg-primary-700 rounded shadow dark:bg-primary-700">
                <div
                    class="flex justify-center items-center mb-4 w-14 h-14 rounded-full bg-primary-500 lg:h-12 lg:w-12 ">
                    <span class="text-white dark:text-primary-100 text-4xl font-bold">{{ loop.index }}</span>
                </div>
                <h3 class="mb-2 text-xl font-bold text-white">{{ step.title }}</h3>
                <div class="text-gray-200 font-light">{{ step.text|markdown }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>