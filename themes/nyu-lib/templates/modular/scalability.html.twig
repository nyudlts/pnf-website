<style>
            price {
                color: var(--color-primary-600);
                font-weight: bold;
            }
        </style>

        {% set background -%}
        {% if page.header.background == 'darker' %}bg-gray-50 dark:bg-gray-950/95{% else %}bg-white dark:bg-gray-900
        {% endif %}
        {%- endset %}

        <section class="{{ background }} relative pb-8 lg:pb-16">
            <div class="py-8 lg:py-16 mx-auto max-w-screen-md text-center">
                <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white">{{ page.title }}</h2>
                {% if page.content|trim %}
                    <div class="font-light text-gray-500 dark:text-gray-400 sm:text-xl">
                        {{ page.content|raw }}
                    </div>
                {% endif %}
            </div>
            <div class="px-4 mx-auto max-w-screen-xl relative ">
                {% for table in page.header.tables %}
                    <div class="md:flex gap-8 md:gap-16 mb-8 md:mb-16">
                        <div class="md:w-1/3 pb-4">
                            <h3 class="pt-2 mb-4 text-lg md:text-[19px] font-semibold text-left rtl:text-right text-gray-900 dark:text-white">
                                {{ table.title }}
                            </h3>
                            <p class="mt-1 text-sm md:text-[15px] font-normal text-gray-500 dark:text-gray-400">{{ table.caption }}</p>
                        </div>
                        <div class="w-full relative overflow-x-auto shadow-md sm:rounded-lg">

                            <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
                                {% set table_headers = table.headers|split('|') %}
                                {% set table_widths = table.widths|split('|') %}
                                <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                                    <tr>
                                        {% for header in table_headers %}
                                            <th scope="col" class="px-6 py-3 {{ table_widths[loop.index0] }}">
                                                {{ header|trim }}
                                            </th>
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in table.rows %}
                                        {% set row_string = row is iterable ? row|join(' | ') : row %}
                                        {% set table_cells = row_string|split('|') %}
                                        <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 border-gray-200">
                                            {% for cell in table_cells %}
                                                <td class="px-6 py-4 [&>svg]:mb-2">
                                                    {{ cell|convert_prices|convert_svgs|markdown(false) }}
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            {% if table.footer %}
                                <div class="px-6 py-4 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700">
                                    {{ table.footer|convert_svgs|markdown(false) }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
