<style>
                price {
                    color: var(--color-primary-600);
                    font-weight: bold;
                }
            </style>

            <section class="bg-gradient-to-b from-gray-50 to-white dark:from-gray-950 to dark:to-gray-900 relative pb-8 lg:pb-16">
                <div class="py-8 lg:py-16 mx-auto max-w-screen-md text-center">
                    <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white">{{ page.title }}</h2>
                    {% if page.content|trim %}
                        <div class="font-light text-gray-500 dark:text-gray-400 sm:text-xl">
                            {{ page.content|raw }}
                        </div>
                    {% endif %}
                </div>
                <div class="px-4 mx-auto max-w-screen-xl relative ">
                    {% for section in page.header.sections %}
                        <div class="md:flex gap-8 md:gap-16 mb-8 md:mb-16">
                            <div class="md:w-1/3 pb-4">
                                <h3 class="pt-2 mb-4 text-lg md:text-[19px] font-semibold text-left rtl:text-right text-gray-900 dark:text-white">
                                    {{ section.title }}
                                </h3>
                                <div class="mt-1 text-sm md:text-[15px] font-normal text-gray-500 dark:text-gray-400 [&_a]:text-primary-500  [&_a]:hover:text-primary-400 [&_a]:mt-4 [&_a]:inline-flex">{{ section.caption|markdown }}</div>
                            </div>
                            <div class="w-full relative overflow-x-auto shadow-md sm:rounded-lg">
                                {% if section.content %}
                                    <div class="feature-content text-gray-500 dark:text-gray-400 bg-white border-b dark:bg-gray-800 dark:border-gray-700 border-gray-200 p-6 [&>h4]:mt-6 [&>h4]:first:mt-0 [&>h4]:mb-2 [&>h4]:text-lg [&>h4]:font-bold [&>h4]:brightness-75 dark:[&>h4]:brightness-150 [&>ul>li]:mb-2 [&_strong]:text-gray-600 dark:[&_strong]:text-gray-300">
                                        {{ section.content|convert_svgs|markdown }}
                                    </div>
                                {% endif %}
                                {% if section.table %}
                                    <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
                                        {% set headers = section.table.headers|default('')|split('|') %}
                                        {% set widths = section.table.widths|default('')|split('|') %}
                                        {% if headers|length and headers[0]|trim != '' %}
                                            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                                                <tr>
                                                    {% for header in headers %}
                                                        <th scope="col" class="px-6 py-3 {{ widths[loop.index0]|default('')|trim }}">
                                                            {{ header|trim }}
                                                        </th>
                                                    {% endfor %}
                                                </tr>
                                            </thead>
                                        {% endif %}
                                        <tbody>
                                            {% for row in section.table.rows %}
                                                {% set row_string = row is iterable ? row|join(' | ') : row %}
                                                {% set table_cells = row_string|split('|') %}
                                                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 border-gray-200">
                                                    {% for cell in table_cells %}
                                                        <td class="px-6 py-4 w-1/{{ table_cells|length }}">
                                                            {{ cell|convert_svgs|markdown(false) }}
                                                        </td>
                                                    {% endfor %}
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                    {% if section.table.footer %}
                                        <div class="px-6 py-4 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700">
                                            {{ section.table.footer|convert_svgs|markdown(false) }}
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>
