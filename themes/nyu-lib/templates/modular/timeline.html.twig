<section class="bg-linear-to-b from-white to-gray-100 dark:from-gray-900 dark:to-gray-800">
    <div class="py-8 px-4 mx-auto max-w-screen-lg sm:py-16 lg:px-6">
        <div class="mx-auto max-w-screen-sm mb-8 lg:mb-16 text-center">
            <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white text-balance">{{ page.title }}</h2>
            {% if page.header.subtitle %}
            <p class="font-light text-gray-500 sm:text-xl dark:text-gray-400">{{ page.header.subtitle }}</p>
        </div>
        {% endif %}
        <div class="max-w-md mx-auto md:text-lg">

            <ol class="relative border-s border-gray-200 dark:border-gray-700">
                {% for time in page.header.timeline %}
                    <li class="mb-10 ms-4">
                        <div
                            class="absolute w-3 h-3 bg-gray-200 rounded-full mt-[9px] -start-1.5 border border-white dark:border-gray-900 dark:bg-gray-700"></div>
                        <time
                            class="mb-1 text-sm font-normal leading-none text-gray-500 dark:text-gray-400">{{ time.date }}</time>
                        {% if time.title %}
                            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{{ time.title }}</h3>
                        {% endif %}
                        <div class="mb-4 text-base font-normal text-gray-600 dark:text-gray-200 [&>p:first-child]:mt-0">
                            {{ time.text|markdown }}
                        </div>
                    </li>
                {% endfor %}
            </ol>
        </div>
    </div>

</section>