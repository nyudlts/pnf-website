{% set content = page.content %}
{% set content_classes = page.header.content_classes %}
{% set prose_classes = page.header.prose_classes|default('prose dark:prose-invert') %}
{% set h1_classes = page.header.h1_classes %}
{% set h2_classes = page.header.h2_classes %}
{% set background = page.header.background|default('bg-white dark:bg-gray-900')  %}
{% set verify_url = page.header.verify_url %}
{% set first = page.header.first %}

<style>
    price {
        color: var(--color-primary-600);
        font-weight: bold;
    }
</style>

<section class="{{ background }} relative py-16 lg:pb-16">
    <div class="absolute bottom-0 left-0 right-0"><img class="w-full h-full object-fill" src="{{ page.media['gme-bg.svg'].url }}" alt="vector background" /></div>
    <div class="mx-auto max-w-screen-xl">
        <div class="px-4 lg:px-6">
            <div class="text-center mb-6">
                {% if first %}
                    <h1 class="mb-8 md:mb-16 text-4xl font-extrabold leading-none {{ h1_classes|default('text-gray-900 dark:text-white md:text-5xl') }} lg:text-6xl tracking-tight">{{ first }}</h1>
                {% else %}
                    <h2 class="mb-4 md:mb-8 inline-flex mx-auto text-4xl tracking-tight font-extrabold border-b-4 {{ h2_classes|default('text-gray-900  border-gray-300 dark:text-white dark:border-gray-700') }}">{{ page.title }}</h2>
                {% endif %}
            </div>
            {% if content|trim %}
            <div class="mx-auto relative {{ prose_classes }} max-w-none mb-8 md:mb-16 {{ content_classes }}">
                    {{ content|raw }}

                <div class="border-2 border-green-600/75 dark:border-green-700/50 rounded-2xl flex text-green-800 overflow-hidden"
                     x-data="{
                         url: '',
                         verifyUrl() {
                             // Use default URL if no input provided
                             let targetUrl = this.url.trim() || 'https://rochen.green';

                             // Add https:// if no protocol is present (for user input)
                             if (this.url.trim() && !targetUrl.match(/^https?:\/\//i)) {
                                 targetUrl = 'https://' + targetUrl;
                             }

                             // URL encode the target URL
                             const encodedUrl = encodeURIComponent(targetUrl);

                             // Build the verification URL
                             const verifyBaseUrl = '{{ verify_url }}';
                             const fullUrl = verifyBaseUrl + encodedUrl;

                             // Open in new tab
                             window.open(fullUrl, '_blank');
                         }
                     }">
                    <input type="text" 
                           x-model="url"
                           @keydown.enter="verifyUrl()"
                           class="flex-1 text-xl border-0 bg-white/95" 
                           placeholder="e.g. https://example.com">
                    <button @click="verifyUrl()"
                            class="bg-green-600/75 dark:bg-green-700/75 hover:bg-green-600 dark:hover:bg-green-700 text-white text-lg rounded-r-xl px-4">Verify Green Status {{ fa_icon('regular/arrow-right-long.svg', 'w-5 h-5 text-white')|raw }}</button>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

</section>
