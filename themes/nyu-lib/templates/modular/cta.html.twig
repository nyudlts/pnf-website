{% set buttons = page.header.buttons %}

{% set bg_classes = page.header.bg_classes|default('bg-gray-50 dark:bg-gray-950') %}

<section class="{{ bg_classes }}">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
        <div class="max-w-screen-md mx-auto text-center">
            <div class="flex flex-col space-y-4 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4">
                {% for button in buttons %}
                    <a href="{{ url(button.link) }}" class="button button__xl {{ button.button_type }}">
                        {{ button.text }}
                    </a>
                {% endfor %}
            </div>
        </div>
        {% if page.content %}
            <div class="prose dark:prose-invert max-w-screen-lg mx-auto md:text-lg mt-12">
                {{ page.content | raw }}
            </div>
        {% endif %}
    </div>
</section>
