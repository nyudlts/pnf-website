{# Guidelines listing template - for the preservation guidelines #}
{% extends 'partials/base.html.twig' %}

{% block content %}
    {% set page_num = (uri.param('page') ?: 1)|int %}
    {% set blog_config = page.header.content %}
    {% set base_limit = (blog_config.limit ?? 0)|int %}
    {% set base_limit = base_limit > 0 ? base_limit : 6 %}
    {% set paginated_collection = page.collection(blog_config) %}
    {% set pagination = paginated_collection.params.pagination|default(null) %}
    {% set collection_params = paginated_collection.params|default({})|merge({'pagination': false, 'limit': 0}) %}
    {% set guidelines_collection = page.collection(collection_params) %}
    {% set total_guidelines = guidelines_collection|length %}
    {% set start = (page_num - 1) * base_limit %}
    {% set guidelines = guidelines_collection|slice(start, base_limit) %}
    {% set guideline_count = guidelines|length %}
    {% set has_next = total_guidelines > start + guideline_count %}
    {% set next_url = null %}
    {% if has_next %}
        {% if pagination and pagination.nextUrl %}
            {% set next_url = (page.url ~ pagination.params ~ pagination.nextUrl)|replace({'//':'/'}) %}
        {% else %}
            {% set next_url = (page.url ~ '/page:' ~ (page_num + 1))|replace({'//':'/'}) %}
        {% endif %}
    {% endif %}

    <div class="pt-6 pb-12 px-4 mx-auto max-w-screen-xl">
        {% set is_htmx = is_htmx|default(false) %}
        {% set start = start|default(0) %}
        {% set guidelines = guidelines|default([]) %}
        {% set search_placeholder = search_placeholder|default('Search...') %}

        <div x-data="guidelinesFilter" class="lg:flex mb-16 lg:-mx-8 lg:divide-x lg:divide-gray-200 dark:lg:divide-gray-700">
            <div class="pb-8 prose lg:px-4 lg:px-8 lg:w-1/3">
                <div class="lg:sticky lg:top-[100px] [&>h3]:mt-0">
                    <h3 id="filters-heading">Filters:</h3>
                    <div class="not-prose" role="search" aria-labelledby="filters-heading">
                        <div class="mb-4">
                            {# WCAG 1.3.1, 3.3.2 - Accessible label for search input #}
                            <label for="guideline-search" class="sr-only">{{ search_placeholder }}</label>
                            <input type="text"
                                   id="guideline-search"
                                   x-model="searchQuery"
                                   @input="onSearchInput()"
                                   placeholder="{{ search_placeholder }}"
                                   class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                        </div>
                        {% include 'partials/taxonomylist.html.twig' with {'base_url':page.url, 'taxonomy':'tag', 'children_only': true, 'of_page': page} %}
                    </div>
                </div>
            </div>
            <div id="blog-col-2" class="space-y-8 lg:px-8 lg:w-2/3">
                {% for guideline in guidelines %}
                    {% include 'partials/guideline-card.html.twig'%}
                {% endfor %}
            </div>
        </div>

    </div>
{% endblock %}
