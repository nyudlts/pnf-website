{% extends 'default.html.twig' %}

{% block content %}
    <main id="body" class="prose dark:prose-invert mx-auto max-w-screen-md pb-16 grid gap-4">
        {% for link in page.collection %}
        <a href="{{ link.url }}" class="inline-flex items-center justify-between p-5 text-base font-medium text-gray-500 rounded-lg bg-gray-50 hover:text-gray-900 hover:bg-gray-100 dark:text-gray-400 dark:bg-gray-800 dark:hover:bg-gray-700 dark:hover:text-white no-underline">
            <div class="inline-flex items-center">
                {{ fa_icon('regular/link.svg', 'text-primary-500 w-6 h-6 mr-2')|raw }}
                <span class="w-full">{{ link.title }}</span>
            </div>
            {{ fa_icon('regular/arrow-right-long.svg', 'text-current w-6 h-6')|raw }}
        </a>
        {% endfor %}
    </main
{% endblock %}
